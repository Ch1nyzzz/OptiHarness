{
  "mem0_source": {
    "infer": true,
    "batch_add": true,
    "mem0_batch_size": 2,
    "vector_store_provider": "qdrant",
    "vector_store_config": {
      "embedding_model_dims": 384
    },
    "llm_provider": "openai",
    "llm_config": {
      "model": "/data/home/yuhan/model_zoo/Qwen3-8B",
      "api_key": "EMPTY",
      "openai_base_url": "http://127.0.0.1:8000/v1",
