# Byte-compiled / optimized / dynamic Python artifacts
__pycache__/
*.py[cod]
*$py.class

# Test, coverage, and type-checker caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Build and packaging artifacts
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual environments and local interpreter state
.venv/
venv/
env/
ENV/
.python-version

# Local configuration and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.token

# Logs and temporary files
*.log
*.tmp
*.temp
.DS_Store

# Runtime outputs from experiments and model/proposer runs
runs/*
!runs/.gitkeep

# Downloaded reference repositories
references/vendor/
